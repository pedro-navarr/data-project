{
  "datasets": [
    {
      "name": "afbfb24f",
      "displayName": "Top Ten Risk Profiles by Accident Count",
      "queryLines": [
        "SELECT * FROM workspace.projeto_analytics_2.perfil_risco_modelo_gold ORDER BY total_acidentes DESC LIMIT 10"
      ]
    },
    {
      "name": "eaccd55c",
      "displayName": "Accident Totals Grouped by State Analysis",
      "queryLines": [
        "SELECT TRIM(UPPER(ocorrencia_uf)) AS Estados, SUM(total_acidentes) as Total_Acidentes FROM workspace.projeto_analytics_2.sazonalidade_horario_gold WHERE ocorrencia_uf != \"NAO INFORMADO\" AND ocorrencia_uf IS NOT NULL GROUP BY Estados"
      ]
    },
    {
      "name": "6d5dff5e",
      "displayName": "Monthly Event Totals Aggregated by Period",
      "queryLines": [
        "SELECT Mes, SUM(total_eventos) AS Total_Eventos FROM workspace.projeto_analytics_2.sazonalidade_horario_gold GROUP BY Mes ORDER BY Mes"
      ]
    },
    {
      "name": "6402e88a",
      "displayName": "Brazilian State Occurrence Summary Dataset",
      "queryLines": [
        "SELECT\r\n",
        "    CASE \r\n",
        "        WHEN ocorrencia_uf = 'SP' THEN 'São Paulo'\r\n",
        "        WHEN ocorrencia_uf = 'RJ' THEN 'Rio de Janeiro'\r\n",
        "        WHEN ocorrencia_uf = 'MG' THEN 'Minas Gerais'\r\n",
        "        WHEN ocorrencia_uf = 'ES' THEN 'Espírito Santo'\r\n",
        "        WHEN ocorrencia_uf = 'AC' THEN 'Acre'\r\n",
        "        WHEN ocorrencia_uf = 'AL' THEN 'Alagoas'\r\n",
        "        WHEN ocorrencia_uf = 'AP' THEN 'Amapá'\r\n",
        "        WHEN ocorrencia_uf = 'AM' THEN 'Amazonas'\r\n",
        "        WHEN ocorrencia_uf = 'BA' THEN 'Bahia'\r\n",
        "        WHEN ocorrencia_uf = 'CE' THEN 'Ceará'\r\n",
        "        WHEN ocorrencia_uf = 'DF' THEN 'Distrito Federal'\r\n",
        "        WHEN ocorrencia_uf = 'GO' THEN 'Goiás'\r\n",
        "        WHEN ocorrencia_uf = 'MA' THEN 'Maranhão'\r\n",
        "        WHEN ocorrencia_uf = 'MT' THEN 'Mato Grosso'\r\n",
        "        WHEN ocorrencia_uf = 'MS' THEN 'Mato Grosso do Sul'\r\n",
        "        WHEN ocorrencia_uf = 'PA' THEN 'Pará'\r\n",
        "        WHEN ocorrencia_uf = 'PB' THEN 'Paraíba'\r\n",
        "        WHEN ocorrencia_uf = 'PE' THEN 'Pernambuco'\r\n",
        "        WHEN ocorrencia_uf = 'PI' THEN 'Piauí'\r\n",
        "        WHEN ocorrencia_uf = 'PR' THEN 'Paraná'\r\n",
        "        WHEN ocorrencia_uf = 'RN' THEN 'Rio Grande do Norte'\r\n",
        "        WHEN ocorrencia_uf = 'RO' THEN 'Rondônia'\r\n",
        "        WHEN ocorrencia_uf = 'RR' THEN 'Roraima'\r\n",
        "        WHEN ocorrencia_uf = 'RS' THEN 'Rio Grande do Sul'\r\n",
        "        WHEN ocorrencia_uf = 'SC' THEN 'Santa Catarina'\r\n",
        "        WHEN ocorrencia_uf = 'SE' THEN 'Sergipe'\r\n",
        "        WHEN ocorrencia_uf = 'TO' THEN 'Tocantins'\r\n",
        "        ELSE ocorrencia_uf \r\n",
        "    END AS Estado_Nome,\r\n",
        "    SUM(total_acidentes) AS Acidentes\r\n",
        "FROM workspace.projeto_analytics_2.sazonalidade_horario_gold\r\n",
        "WHERE ocorrencia_uf != \"NAO INFORMADO\"\r\n",
        "GROUP BY Estado_Nome"
      ],
      "catalog": "workspace",
      "schema": "projeto_analytics_2"
    },
    {
      "name": "18c318b8",
      "displayName": "Aeronautical Incident Classification Counts Summary",
      "queryLines": [
        "SELECT \r\n",
        "    ocorrencia_classificacao,\r\n",
        "    COUNT(*) AS Total\r\n",
        "FROM\r\n",
        "    workspace.projeto_analytics_2.aeronautica_ocorrencia_silver\r\n",
        "WHERE\r\n",
        "    ocorrencia_classificacAO IS NOT NULL\r\n",
        "GROUP BY \r\n",
        "    ocorrencia_classificacao"
      ]
    },
    {
      "name": "c5e365cc",
      "displayName": "Aircraft Engine Types and Incident Classification Counts",
      "queryLines": [
        "SELECT\r\n",
        "    aa.aeronave_motor_tipo,\r\n",
        "    ao.ocorrencia_classificacao,\r\n",
        "    COUNT(*) AS Total\r\n",
        "FROM\r\n",
        "    workspace.projeto_analytics_2.aeronautica_aeronave_silver AS aa\r\n",
        "INNER JOIN\r\n",
        "        workspace.projeto_analytics_2.aeronautica_ocorrencia_silver AS ao ON aa.codigo_ocorrencia2 = ao.codigo_ocorrencia\r\n",
        "WHERE\r\n",
        "    aa.aeronave_motor_tipo != \"NAO INFORMADO\"\r\n",
        "GROUP BY\r\n",
        "    aa.aeronave_motor_tipo,\r\n",
        "    ao.ocorrencia_classificacao\r\n",
        "ORDER BY\r\n",
        "     Total DESC\r\n",
        "\r\n"
      ],
      "catalog": "workspace",
      "schema": "projeto_analytics_2"
    }
  ],
